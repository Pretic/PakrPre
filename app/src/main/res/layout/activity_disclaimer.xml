<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="52dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="免责声明"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#0D0D0D"
            android:letterSpacing="0.02"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="请仔细阅读以下条款，使用即表示同意"
            android:textSize="14sp"
            android:textColor="#888888" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0" />

    <ScrollView
        android:id="@+id/scrollDisclaimer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <TextView
            android:id="@+id/tvDisclaimerBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="#333333"
            android:lineSpacingMultiplier="1.75"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp" />
    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0" />

    <CheckBox
        android:id="@+id/cbAgree"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="我已阅读并理解以上内容，承诺合法合规使用"
        android:textSize="14sp"
        android:textColor="#333333"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:button="@drawable/cb_circle_selector" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="4dp"
        android:paddingBottom="32dp">

        <Button
            android:id="@+id/btnDecline"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="不同意"
            android:textSize="15sp"
            android:textColor="#555555"
            android:background="@drawable/btn_rounded_gray"
            android:layout_marginEnd="12dp"
            android:stateListAnimator="@null"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <Button
            android:id="@+id/btnAccept"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="2"
            android:text="同意并继续"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_rounded_black"
            android:stateListAnimator="@null"
            android:insetTop="0dp"
            android:insetBottom="0dp" />
    </LinearLayout>
</LinearLayout>
